{
  "name": "@gotgenes/opencode-session-context",
  "version": "1.4.1",
  "description": "OpenCode plugin for cross-session context access in subagent workflows",
  "author": {
    "name": "Chris Lasher"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && bun run build:types",
    "build:types": "tsc --project tsconfig.build.json --noEmitOnError false",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:md": "markdownlint-cli2 '*.md'",
    "lint:all": "bun run lint && bun run lint:md",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "session",
    "subagent",
    "context"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gotgenes/opencode-session-context.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@opencode-ai/sdk": "^1.14.18",
    "bun-types": "^1.3.12",
    "markdownlint-cli2": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
